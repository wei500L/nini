# deepseek / qwen / kimi / glm / claude
LLM_PROVIDER=deepseek

# 可以统一使用 LLM_*，也可以使用 DEEPSEEK_API_KEY 等厂商前缀变量。
LLM_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com
# LLM_FAST_MODEL=deepseek-v4-pro
# LLM_SMART_MODEL=deepseek-v4-pro
# LLM_THINKING_TYPE=enabled
# LLM_REASONING_EFFORT=high
# LLM_TIMEOUT_SECONDS=90

# Writer 搜索工具。real 模式下失败会直接报错，不会退回 fixture。
# TAVILY_MODE=real
# TAVILY_MCP_URL=https://example.com/mcp
# TAVILY_API_KEY=
# REST 模式兼容项；使用 MCP 时无需配置。
# TAVILY_BASE_URL=https://api.tavily.com

# 本地语音转录；模型首次使用时从 ModelScope 下载到缓存目录。
WHISPER_MODEL_ID=openai-mirror/whisper-medium
WHISPER_DEVICE=auto
WHISPER_LANGUAGE=zh
WHISPER_MAX_AUDIO_SECONDS=90
WHISPER_CACHE_DIR=./.cache/modelscope
